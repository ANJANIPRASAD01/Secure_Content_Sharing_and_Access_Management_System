# =================================================================
# RENDER DEPLOYMENT ENVIRONMENT VARIABLES
# Database: Railway MySQL
# =================================================================

# Server Configuration
PORT=8080
JAVA_OPTS=-Xmx512m

# =================================================================
# DATABASE - Railway MySQL (REQUIRED)
# =================================================================
SPRING_DATASOURCE_URL=jdbc:mysql://crossover.proxy.rlwy.net:12147/railway
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=wswhXQBLzdCSboUDCtEvaTibJmUWkdOz
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# =================================================================
# JPA/Hibernate Configuration
# =================================================================
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.MySQL8Dialect
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

# =================================================================
# JWT Security (CHANGE THIS TO A STRONG RANDOM KEY!)
# =================================================================
JWT_SECRET=your-super-secret-key-change-this-to-something-random-atleast-32-characters-long
JWT_EXPIRATION=86400000

# =================================================================
# CORS Configuration (Update with your Vercel frontend URL)
# =================================================================
CORS_ORIGINS=https://your-vercel-frontend-url.vercel.app

# =================================================================
# Logging Configuration
# =================================================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_FILEVAULT=DEBUG

# =================================================================
# File Upload Configuration
# =================================================================
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=100MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=100MB
FILE_UPLOAD_DIR=uploads

# =================================================================
# Twilio SMS Configuration (Optional - for SMS notifications)
# =================================================================
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890
