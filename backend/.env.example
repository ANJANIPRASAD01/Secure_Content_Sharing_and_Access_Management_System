# Server Configuration
PORT=8080
JAVA_OPTS=-Xmx512m

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://your-database-host:3306/filevault_db
SPRING_DATASOURCE_USERNAME=your_database_user
SPRING_DATASOURCE_PASSWORD=your_database_password
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# JPA/Hibernate Configuration
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.MySQL8Dialect
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

# Logging Configuration
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_FILEVAULT=DEBUG

# JWT Configuration (SECURITY: Change these values in production!)
JWT_SECRET=your-super-secret-key-change-this-in-production-must-be-at-least-32-characters-long
JWT_EXPIRATION=86400000

# File Upload Configuration
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=100MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=100MB
FILE_UPLOAD_DIR=uploads

# CORS Configuration
CORS_ORIGINS=https://your-vercel-frontend-url.vercel.app,https://www.your-vercel-frontend-url.vercel.app
